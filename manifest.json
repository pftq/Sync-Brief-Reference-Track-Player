{
  "manifest_version": 3,
  "name": "Sync Brief Track Preview",
  "version": "1.0",
  "description": "Hover over track references in Sync Brief emails to preview them on YouTube.",
  "permissions": ["activeTab", "contextMenus"],
  "host_permissions": ["https://www.youtube.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["player.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["patterns.txt"],
      "matches": ["https://mail.google.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
